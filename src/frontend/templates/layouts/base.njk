<!DOCTYPE html>
<html lang="es" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#0C0C0F">
    <title>{% block title %}ProWay Lab{% endblock %}</title>
    <meta name="description" content="{% block description %}Agencia de producción de video profesional{% endblock %}">

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/images/imagotipo-proway-blanco.png">

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="apple-touch-icon" href="/images/pwa-icon-192.png">

    <!-- Preconnect for fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <!-- ProWay Design System -->
    <link rel="stylesheet" href="/dist/assets/module.css?v=3">

    {% block head %}{% endblock %}
</head>
<body>
    <div id="toast-container" aria-live="polite"></div>

    <!-- PWA Install Banner -->
    <div x-data="pwaInstall" x-show="canInstall" x-transition.opacity
         style="position:fixed;bottom:1rem;left:50%;transform:translateX(-50%);z-index:9999;
                background:linear-gradient(135deg,#0f172a,#1e293b);border:1px solid rgba(0,217,255,.25);
                border-radius:.75rem;padding:.75rem 1.25rem;display:flex;align-items:center;gap:.75rem;
                box-shadow:0 8px 32px rgba(0,0,0,.5);max-width:calc(100vw - 2rem);width:420px"
         x-cloak>
        <img src="/images/pwa-icon-192.png" alt="" width="36" height="36" style="border-radius:.5rem">
        <div style="flex:1;min-width:0">
            <p style="font-size:.85rem;font-weight:600;color:#fff;margin:0">Instalar ProWay Lab</p>
            <p style="font-size:.75rem;color:#94a3b8;margin:0">Accede desde tu pantalla de inicio</p>
        </div>
        <button @click="install()" style="padding:.4rem 1rem;background:#00D9FF;color:#0C0C0F;
                font-weight:600;font-size:.8rem;border:none;border-radius:.375rem;cursor:pointer;white-space:nowrap">
            Instalar
        </button>
        <button @click="dismiss()" style="background:none;border:none;color:#64748b;cursor:pointer;
                font-size:1.1rem;padding:.25rem;line-height:1" aria-label="Cerrar">&times;</button>
    </div>

    {% block body %}{% endblock %}

    <!-- JS: HTMX + Alpine.js (injected by Vite) -->
    {% block scripts %}
    <script type="module" src="/dist/assets/main.js?v=3"></script>
    {% endblock %}
</body>
</html>
