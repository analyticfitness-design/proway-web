{% extends "layouts/base.njk" %}

{% block body %}
<!-- Scroll progress bar -->
<div id="scroll-progress"></div>

<div class="page flex">
    <!-- Mobile hamburger -->
    <button class="mobile-menu-toggle" id="mobile-menu-btn" aria-label="Menu"
            onclick="document.getElementById('sidebar').classList.toggle('is-open')">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
    </button>

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar" x-data="{ open: false }" :class="{ 'is-open': open }">
        <div class="sidebar__logo">
            <img src="/images/imagotipo-proway-blanco.png" alt="PW" width="28" height="28">
            <span class="sidebar__logo-text">ProWay</span>
        </div>

        <nav class="sidebar__nav">
            {% block sidebar_nav %}{% endblock %}
        </nav>

        <div class="sidebar__footer">
            {% block sidebar_footer %}{% endblock %}
        </div>
    </aside>

    <!-- Main content -->
    <main class="main-with-sidebar page-content" id="main-content">
        <div class="page-header">
            <h1 class="page-title">{% block page_title %}{% endblock %}</h1>
            <div class="flex gap-4">{% block page_actions %}{% endblock %}</div>
        </div>

        {% block content %}{% endblock %}
    </main>
</div>

<script>
(function() {
    var bar = document.getElementById('scroll-progress');
    if (bar) {
        var main = document.getElementById('main-content');
        (main || window).addEventListener('scroll', function() {
            var el = main || document.documentElement;
            var scrollTop = main ? el.scrollTop : (window.pageYOffset || el.scrollTop);
            var scrollHeight = el.scrollHeight - el.clientHeight;
            bar.style.width = scrollHeight > 0 ? (scrollTop / scrollHeight * 100) + '%' : '0%';
        });
    }
})();
</script>
{% endblock %}
