{% extends "layouts/base.njk" %}

{% block body %}
<!-- Scroll progress bar -->
<div id="scroll-progress"></div>

<div class="page flex">
    <!-- Mobile hamburger -->
    <button class="mobile-menu-toggle" id="mobile-menu-btn" aria-label="Menu"
            onclick="document.getElementById('sidebar').classList.toggle('is-open')">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
    </button>

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar" x-data="{ open: false }" :class="{ 'is-open': open }">
        <div class="sidebar__logo">
            <img src="/images/imagotipo-proway-blanco.png" alt="PW" width="28" height="28">
            <span class="sidebar__logo-text">ProWay</span>
        </div>

        <nav class="sidebar__nav">
            {% block sidebar_nav %}{% endblock %}
        </nav>

        <div class="sidebar__footer">
            <!-- Notification bell -->
            <button class="notif-bell" id="notif-toggle" onclick="document.getElementById('notif-panel').classList.toggle('is-open')">
                <span class="notif-bell__icon" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                        <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                    </svg>
                </span>
                Notificaciones
                <span class="notif-badge" id="notif-badge"
                      hx-get="/api/v1/notifications/unread-count"
                      hx-trigger="load, refreshBadge from:body, every 30s"
                      hx-swap="innerHTML"
                      hx-select-oob="false"
                      hx-on::after-request="var d=JSON.parse(event.detail.xhr.responseText);var c=d&&d.data?d.data.count:0;this.textContent=c>0?c:'';this.dataset.count=c;"></span>
            </button>

            <!-- Notification dropdown panel -->
            <div class="notif-panel" id="notif-panel">
                <div class="notif-panel__header">
                    <span class="notif-panel__title">Notificaciones</span>
                    <button class="notif-panel__mark-all"
                            onclick="fetch('/api/v1/notifications/mark-all-read',{method:'PATCH',credentials:'include'}).then(()=>{htmx.trigger('#notif-list','revealed');htmx.trigger('#notif-badge','refreshBadge')})">
                        Marcar todas
                    </button>
                </div>
                <div class="notif-panel__body" id="notif-list"
                     hx-get="/api/partials/notifications.php"
                     hx-trigger="revealed"
                     hx-swap="innerHTML">
                </div>
            </div>

            {% block sidebar_footer %}{% endblock %}
        </div>
    </aside>

    <!-- Main content -->
    <main class="main-with-sidebar page-content" id="main-content">
        <div class="page-header">
            <h1 class="page-title">{% block page_title %}{% endblock %}</h1>
            <div class="flex gap-4">{% block page_actions %}{% endblock %}</div>
        </div>

        {% block content %}{% endblock %}
    </main>
</div>

<script>
(function() {
    var bar = document.getElementById('scroll-progress');
    if (bar) {
        var main = document.getElementById('main-content');
        (main || window).addEventListener('scroll', function() {
            var el = main || document.documentElement;
            var scrollTop = main ? el.scrollTop : (window.pageYOffset || el.scrollTop);
            var scrollHeight = el.scrollHeight - el.clientHeight;
            bar.style.width = scrollHeight > 0 ? (scrollTop / scrollHeight * 100) + '%' : '0%';
        });
    }
})();
</script>
{% endblock %}
