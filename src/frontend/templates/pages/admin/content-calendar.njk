{% block sidebar_footer %}
<button class="btn btn--ghost btn--full"
        style="justify-content:flex-start; gap: var(--pw-space-2);"
        @click="fetch('/api/v1/auth/logout', {method:'POST', credentials:'include'}).then(() => window.location.href = '/login')">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
        <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
    </svg>
    Cerrar Sesion
</button>
{% endblock %}

{# ── Page actions ────────────────────────────────────────── #}
{% block page_actions %}
<span id="cal-spinner" class="htmx-indicator" aria-label="Cargando calendario">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
         style="animation: pw-spin 0.8s linear infinite; color: var(--pw-accent);" aria-hidden="true">
        <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
    </svg>
</span>

<button class="btn btn--ghost btn--sm"
        hx-get="/api/partials/content-calendar.php"
        hx-target="#calendar-container"
        hx-swap="innerHTML"
        hx-headers='{"X-Requested-With": "XMLHttpRequest"}'
        hx-indicator="#cal-spinner"
        title="Actualizar calendario">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <polyline points="23 4 23 10 17 10"/>
        <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
    </svg>
    Actualizar
</button>
{% endblock %}

{# ── Main content ────────────────────────────────────────── #}
{% block content %}

<!-- Client filter + horizon tabs -->
<div style="display:flex;align-items:center;gap:var(--pw-space-3);flex-wrap:wrap;margin-bottom:var(--pw-space-3);"
     x-data="{ clientId: '', horizon: 30 }">

    <div style="display:flex;align-items:center;gap:var(--pw-space-2);">
        <label style="font-size:0.8rem;font-weight:600;color:var(--pw-text-muted);">Cliente:</label>
        <select x-model="clientId"
                @change="htmx.ajax('GET', '/api/partials/content-calendar.php' + (clientId ? '?client_id=' + clientId : ''), '#calendar-container')"
                style="background:var(--pw-bg);border:1px solid var(--pw-border);border-radius:var(--pw-radius-md);padding:var(--pw-space-1) var(--pw-space-2);font-size:0.82rem;color:var(--pw-text);min-width:180px;">
            <option value="">Todos los clientes</option>
        </select>
    </div>

    <div style="display:flex;gap:2px;background:var(--pw-bg);border:1px solid var(--pw-border);border-radius:var(--pw-radius-md);padding:2px;">
        <template x-for="h in [30, 60, 90]" :key="h">
            <button class="btn btn--ghost btn--sm"
                    :class="{ 'btn--active-tab': horizon === h }"
                    @click="horizon = h"
                    x-text="h + 'd'"
                    style="font-size:0.75rem;padding:4px 12px;border-radius:var(--pw-radius-sm);"></button>
        </template>
    </div>
</div>

<div id="calendar-container"
     hx-get="/api/partials/content-calendar.php"
     hx-trigger="load"
     hx-swap="innerHTML"
     hx-headers='{"X-Requested-With": "XMLHttpRequest"}'
     hx-indicator="#cal-spinner">

    <!-- Skeleton while loading -->
    <div aria-busy="true" aria-label="Cargando calendario de contenido">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--pw-space-3);">
            <div style="display:flex;align-items:center;gap:var(--pw-space-2);">
                <span class="skeleton-text" style="width:30px;height:30px;border-radius:var(--pw-radius-md);"></span>
                <span class="skeleton-text" style="width:150px;height:20px;"></span>
                <span class="skeleton-text" style="width:30px;height:30px;border-radius:var(--pw-radius-md);"></span>
            </div>
            <div style="display:flex;gap:0.5rem;">
                <span class="skeleton-text" style="width:50px;height:12px;"></span>
                <span class="skeleton-text" style="width:50px;height:12px;"></span>
                <span class="skeleton-text" style="width:50px;height:12px;"></span>
            </div>
        </div>
        <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:1px;background:var(--pw-border);border:1px solid var(--pw-border);border-radius:var(--pw-radius-lg);overflow:hidden;">
            {% for i in range(0, 7) %}
            <div style="background:var(--pw-panel);padding:var(--pw-space-2);text-align:center;">
                <span class="skeleton-text" style="width:30px;height:12px;"></span>
            </div>
            {% endfor %}
            {% for i in range(0, 35) %}
            <div style="background:var(--pw-bg);min-height:80px;padding:var(--pw-space-1);">
                <span class="skeleton-text" style="width:20px;height:14px;float:right;"></span>
            </div>
            {% endfor %}
        </div>
    </div>

</div>

<style>
@keyframes pw-spin { to { transform: rotate(360deg); } }

@keyframes pw-skeleton-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.35; }
}
.loading-skeleton { pointer-events: none; animation: pw-skeleton-pulse 1.4s ease-in-out infinite; }
.skeleton-text {
    display: inline-block;
    height: 14px;
    background: var(--pw-border-2);
    border-radius: var(--pw-radius-sm);
    animation: pw-skeleton-pulse 1.4s ease-in-out infinite;
}

.htmx-indicator { opacity: 0; transition: opacity 0.2s; pointer-events: none; }
.htmx-request .htmx-indicator,
.htmx-indicator.htmx-request { opacity: 1; }

.btn--active-tab {
    background: var(--pw-accent, #00D9FF) !important;
    color: var(--pw-black, #0C0C0F) !important;
    font-weight: 600 !important;
}
</style>

<script>
document.body.addEventListener('htmx:responseError', function(evt) {
    if (evt.detail.xhr.status === 401) {
        window.location.href = '/login';
    }
});

// Populate client dropdown from API
(async function() {
    try {
        const res = await fetch('/api/v1/clients', { credentials: 'include' });
        if (!res.ok) return;
        const json = await res.json();
        const clients = json.data?.clients || json.data || [];
        const sel = document.querySelector('#calendar-container')?.previousElementSibling?.querySelector('select');
        if (!sel || !Array.isArray(clients)) return;
        clients.forEach(function(c) {
            const opt = document.createElement('option');
            opt.value = c.id;
            opt.textContent = c.name;
            sel.appendChild(opt);
        });
    } catch(e) {}
})();
</script>
{% endblock %}

{% block scripts %}
<script type="module" src="/dist/assets/admin.js"></script>
{% endblock %}
