{# ── Page actions ────────────────────────────────────────── #}
{% block page_actions %}
<span id="alib-spinner" class="htmx-indicator" aria-label="Cargando assets">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
         style="animation: pw-spin 0.8s linear infinite; color: var(--pw-accent);" aria-hidden="true">
        <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
    </svg>
</span>

<button class="btn btn--ghost btn--sm"
        hx-get="/api/partials/asset-library.php"
        hx-target="#asset-library-root"
        hx-swap="innerHTML"
        hx-headers='{"X-Requested-With": "XMLHttpRequest"}'
        hx-indicator="#alib-spinner"
        title="Actualizar biblioteca">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <polyline points="23 4 23 10 17 10"/>
        <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
    </svg>
    Actualizar
</button>
{% endblock %}

{# ── Main content ────────────────────────────────────────── #}
{% block content %}

<div id="asset-library-root"
     hx-get="/api/partials/asset-library.php"
     hx-trigger="load"
     hx-swap="innerHTML"
     hx-headers='{"X-Requested-With": "XMLHttpRequest"}'
     hx-indicator="#alib-spinner">

    <!-- Skeleton while loading -->
    <div aria-busy="true" aria-label="Cargando biblioteca de assets">
        <!-- Search skeleton -->
        <div style="display:flex;gap:var(--pw-space-3);margin-bottom:var(--pw-space-3);flex-wrap:wrap;">
            <span class="skeleton-text" style="flex:1;min-width:200px;height:36px;border-radius:var(--pw-radius-md);"></span>
            <span class="skeleton-text" style="width:140px;height:36px;border-radius:var(--pw-radius-md);"></span>
            <span class="skeleton-text" style="width:140px;height:36px;border-radius:var(--pw-radius-md);"></span>
        </div>
        <span class="skeleton-text" style="width:120px;height:14px;margin-bottom:var(--pw-space-3);display:block;"></span>
        <!-- Grid skeleton -->
        <div style="display:grid;grid-template-columns:repeat(auto-fill, minmax(220px, 1fr));gap:var(--pw-space-3);">
            {% for i in range(0, 8) %}
            <div style="background:var(--pw-panel);border:1px solid var(--pw-border);border-radius:var(--pw-radius-lg);overflow:hidden;">
                <span class="skeleton-text" style="width:100%;height:0;padding-bottom:62.5%;display:block;border-radius:0;"></span>
                <div style="padding:var(--pw-space-2) var(--pw-space-3);">
                    <span class="skeleton-text" style="width:80%;height:14px;margin-bottom:4px;"></span>
                    <span class="skeleton-text" style="width:50%;height:10px;"></span>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

</div>

<!-- Container for preview modal (populated via HTMX) -->
<div id="asset-preview-container"></div>

<style>
@keyframes pw-spin { to { transform: rotate(360deg); } }

@keyframes pw-skeleton-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.35; }
}
.skeleton-text {
    display: inline-block;
    height: 14px;
    background: var(--pw-border-2);
    border-radius: var(--pw-radius-sm);
    animation: pw-skeleton-pulse 1.4s ease-in-out infinite;
}

.htmx-indicator { opacity: 0; transition: opacity 0.2s; pointer-events: none; }
.htmx-request .htmx-indicator,
.htmx-indicator.htmx-request { opacity: 1; }
</style>

<script>
document.body.addEventListener('htmx:responseError', function(evt) {
    if (evt.detail.xhr.status === 401) {
        window.location.href = '/login';
    }
});
</script>
{% endblock %}

{% block scripts %}
<script type="module" src="/dist/assets/admin.js"></script>
{% endblock %}
