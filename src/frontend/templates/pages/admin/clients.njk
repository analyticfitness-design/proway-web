{# ── Page actions ────────────────────────────────────────── #}
{% block page_actions %}
<span id="clients-spinner" class="htmx-indicator" aria-label="Actualizando clientes">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
         style="animation: pw-spin 0.8s linear infinite; color: var(--pw-accent);" aria-hidden="true">
        <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
    </svg>
</span>

<button class="btn btn--ghost btn--sm"
        hx-get="/api/partials/admin-clients.php"
        hx-target="#clients-table-container"
        hx-swap="innerHTML"
        hx-headers='{"X-Requested-With": "XMLHttpRequest"}'
        hx-indicator="#clients-spinner"
        title="Actualizar lista">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <polyline points="23 4 23 10 17 10"/>
        <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
    </svg>
    Actualizar
</button>

<button class="btn btn--primary btn--sm" @click="$dispatch('open-new-client')">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    Nuevo Cliente
</button>
{% endblock %}

{# ── Main content ────────────────────────────────────────── #}
{% block content %}

<div class="card" x-data="{ search: '' }">
    <div class="card__header">
        <h2 class="card__title">Todos los Clientes</h2>

        <!-- Search input (Alpine.js local filter) -->
        <div style="position: relative; display: flex; align-items: center;">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 aria-hidden="true"
                 style="position:absolute; left: var(--pw-space-3); color: var(--pw-text-muted); pointer-events:none;">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="search"
                   class="form-input"
                   x-model="search"
                   placeholder="Buscar cliente..."
                   autocomplete="off"
                   aria-label="Buscar clientes"
                   style="padding-left: calc(var(--pw-space-3) + 15px + var(--pw-space-2)); width: 220px; height: 36px; font-size: var(--pw-text-sm);">
        </div>
    </div>

    <!-- Clients table loaded via HTMX; Alpine filters rows client-side after load -->
    <div id="clients-table-container"
         hx-get="/api/partials/admin-clients.php"
         hx-trigger="load"
         hx-swap="innerHTML"
         hx-headers='{"X-Requested-With": "XMLHttpRequest"}'
         hx-indicator="#clients-spinner">

        <!-- Skeleton loader while HTMX fetches -->
        <div class="table-wrapper" aria-busy="true" aria-label="Cargando clientes">
            <table class="table">
                <thead>
                    <tr>
                        <th>Cliente</th>
                        <th>Email</th>
                        <th>Plan</th>
                        <th>Estado</th>
                        <th>Proyectos</th>
                        <th>Registro</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {% for i in range(0, 8) %}
                    <tr class="loading-skeleton" aria-hidden="true">
                        <td><span class="skeleton-text" style="width: 130px;"></span></td>
                        <td><span class="skeleton-text" style="width: 170px;"></span></td>
                        <td><span class="skeleton-text" style="width: 70px;"></span></td>
                        <td><span class="skeleton-text" style="width: 65px; border-radius: var(--pw-radius-full);"></span></td>
                        <td><span class="skeleton-text" style="width: 30px;"></span></td>
                        <td><span class="skeleton-text" style="width: 90px;"></span></td>
                        <td><span class="skeleton-text" style="width: 80px;"></span></td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

    </div>

    {#
        After HTMX loads the table, Alpine.js x-model="search" drives
        client-side row filtering. The partial at /api/partials/admin-clients.php
        should render each <tr> with a data-search attribute containing
        lowercase name+email so the filter below works without a round-trip.

        Example partial row:
          <tr data-search="nombre apellido email@domain.com">...</tr>

        The htmx:afterSwap listener below binds the filter once the DOM is ready.
    #}
</div>

<!-- ── Modal: Nuevo Cliente ────────────────────────────── -->
<div x-data="newClientModal()"
     x-show="open"
     x-cloak
     @open-new-client.window="open = true"
     @keydown.escape.window="open && close()"
     style="position:fixed;inset:0;z-index:50;display:flex;align-items:center;justify-content:center;padding:var(--pw-space-4);">

    <!-- Backdrop -->
    <div style="position:absolute;inset:0;background:rgba(0,0,0,.65);" @click="close()"></div>

    <!-- Dialog -->
    <div role="dialog" aria-modal="true" aria-labelledby="ncm-title"
         style="position:relative;width:100%;max-width:480px;background:var(--pw-surface-1);border:1px solid var(--pw-border-1);border-radius:var(--pw-radius-lg);padding:var(--pw-space-6);z-index:1;">

        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--pw-space-5);">
            <h2 id="ncm-title" style="font-size:var(--pw-text-lg);font-weight:600;margin:0;">Nuevo Cliente</h2>
            <button @click="close()" class="btn btn--ghost btn--icon" aria-label="Cerrar">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>

        <form @submit.prevent="submit()" novalidate>
            <div class="form-group">
                <label class="form-label" for="ncm-name">Nombre completo <span aria-hidden="true" style="color:var(--pw-accent)">*</span></label>
                <input id="ncm-name" type="text" class="form-input" x-model="form.name" required autocomplete="off" placeholder="Ej. Ana García">
            </div>

            <div class="form-group" style="margin-top:var(--pw-space-4);">
                <label class="form-label" for="ncm-email">Email <span aria-hidden="true" style="color:var(--pw-accent)">*</span></label>
                <input id="ncm-email" type="email" class="form-input" x-model="form.email" required autocomplete="off" placeholder="cliente@empresa.com">
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--pw-space-3);margin-top:var(--pw-space-4);">
                <div class="form-group">
                    <label class="form-label" for="ncm-phone">Teléfono</label>
                    <input id="ncm-phone" type="tel" class="form-input" x-model="form.phone" placeholder="+57 300 000 0000">
                </div>
                <div class="form-group">
                    <label class="form-label" for="ncm-company">Empresa</label>
                    <input id="ncm-company" type="text" class="form-input" x-model="form.company" placeholder="Opcional">
                </div>
            </div>

            <div class="form-group" style="margin-top:var(--pw-space-4);">
                <label class="form-label" for="ncm-plan">Plan</label>
                <select id="ncm-plan" class="form-input" x-model="form.plan_type">
                    <option value="video_individual">Video Individual</option>
                    <option value="starter">Starter</option>
                    <option value="growth">Growth</option>
                    <option value="authority">Authority</option>
                </select>
            </div>

            <div class="form-group" style="margin-top:var(--pw-space-4);">
                <label class="form-label" for="ncm-password">Contraseña temporal <span aria-hidden="true" style="color:var(--pw-accent)">*</span></label>
                <input id="ncm-password" type="text" class="form-input" x-model="form.password" required autocomplete="off" placeholder="El cliente deberá cambiarla">
            </div>

            <template x-if="error">
                <p style="color:var(--pw-accent);font-size:var(--pw-text-sm);margin-top:var(--pw-space-3);" x-text="error" role="alert"></p>
            </template>

            <div style="display:flex;gap:var(--pw-space-3);justify-content:flex-end;margin-top:var(--pw-space-6);">
                <button type="button" class="btn btn--ghost" @click="close()">Cancelar</button>
                <button type="submit" class="btn btn--primary" :disabled="loading">
                    <span x-show="!loading">Crear Cliente</span>
                    <span x-show="loading">Creando...</span>
                </button>
            </div>
        </form>
    </div>
</div>

<style>
@keyframes pw-spin { to { transform: rotate(360deg); } }

@keyframes pw-skeleton-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.35; }
}
.loading-skeleton { pointer-events: none; }
.skeleton-text {
    display: inline-block;
    height: 14px;
    background: var(--pw-border-2);
    border-radius: var(--pw-radius-sm);
    animation: pw-skeleton-pulse 1.4s ease-in-out infinite;
}

.htmx-indicator { opacity: 0; transition: opacity 0.2s; pointer-events: none; }
.htmx-request .htmx-indicator,
.htmx-indicator.htmx-request { opacity: 1; }
</style>

<script>
/* ── Client-side row filter ─────────────────────────────────
   Runs whenever the Alpine search value changes. Filters <tr>
   elements by their data-search attribute (set by the PHP partial).
   Falls back gracefully if rows have no data-search attribute.
   ──────────────────────────────────────────────────────────── */
(function() {
    function bindSearch() {
        var cardEl = document.querySelector('[x-data]');
        if (!cardEl || !window.Alpine) return;

        // Watch Alpine's reactive `search` property via a DOM watcher
        var inputEl = cardEl.querySelector('input[type="search"]');
        if (!inputEl) return;

        inputEl.addEventListener('input', filterRows);
    }

    function filterRows() {
        var cardEl = document.querySelector('[x-data]');
        if (!cardEl) return;
        var term = (cardEl.querySelector('input[type="search"]') || {}).value || '';
        var lower = term.toLowerCase().trim();
        var rows  = document.querySelectorAll('#clients-table-container tbody tr');

        rows.forEach(function(row) {
            var haystack = (row.dataset.search || row.textContent || '').toLowerCase();
            row.style.display = (!lower || haystack.includes(lower)) ? '' : 'none';
        });
    }

    /* Re-bind after each HTMX swap so the listener works on fresh DOM */
    document.body.addEventListener('htmx:afterSwap', function(evt) {
        if (evt.detail.target && evt.detail.target.id === 'clients-table-container') {
            bindSearch();
            filterRows(); // apply any existing search term immediately
        }
    });

    /* Initial bind on page load */
    document.addEventListener('DOMContentLoaded', bindSearch);
})();

document.body.addEventListener('htmx:responseError', function(evt) {
    if (evt.detail.xhr.status === 401) {
        window.location.href = '/login';
    }
});

function newClientModal() {
    return {
        open: false,
        loading: false,
        error: '',
        form: { name: '', email: '', phone: '', company: '', plan_type: 'starter', password: '' },

        close() {
            this.open = false;
            this.error = '';
            this.form = { name: '', email: '', phone: '', company: '', plan_type: 'starter', password: '' };
        },

        async submit() {
            this.error = '';
            this.loading = true;
            try {
                const res = await fetch('/api/v1/admin/clients', {
                    method: 'POST',
                    credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(this.form),
                });
                const data = await res.json();
                if (!res.ok) {
                    this.error = data?.error?.message || 'Error al crear el cliente';
                    return;
                }
                this.close();
                // Reload table
                htmx.trigger('#clients-table-container', 'load');
            } catch (e) {
                this.error = 'Error de conexión';
            } finally {
                this.loading = false;
            }
        },
    };
}
</script>
{% endblock %}

{% block scripts %}
<script type="module" src="/dist/assets/admin.js"></script>
{% endblock %}
