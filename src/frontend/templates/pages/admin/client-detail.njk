{# ── Page actions ────────────────────────────────────────── #}
{% block page_actions %}
<a href="/admin/clientes" class="btn btn--ghost btn--sm">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
    </svg>
    Volver a Clientes
</a>
{% endblock %}

{# ── Main content ────────────────────────────────────────── #}
{% block content %}

<div x-data="clientDetail()" x-init="load()">

    <!-- Loading state -->
    <template x-if="loading">
        <div style="text-align:center; padding: var(--pw-space-8);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 style="animation: pw-spin 0.8s linear infinite; color: var(--pw-accent);" aria-hidden="true">
                <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
            </svg>
            <p style="margin-top: var(--pw-space-2); color: var(--pw-text-muted);">Cargando datos del cliente...</p>
        </div>
    </template>

    <!-- Error state -->
    <template x-if="error">
        <div class="card" style="text-align:center; padding: var(--pw-space-8);">
            <p style="color: var(--pw-danger);" x-text="error"></p>
            <a href="/admin/clientes" class="btn btn--ghost" style="margin-top: var(--pw-space-4);">Volver a Clientes</a>
        </div>
    </template>

    <!-- Client info -->
    <template x-if="client && !loading">
        <div>
            <!-- Client card -->
            <div class="card" style="margin-bottom: var(--pw-space-5);">
                <div class="card__header" style="display:flex; justify-content:space-between; align-items:center;">
                    <div>
                        <h2 class="card__title" x-text="client.name" style="margin-bottom: var(--pw-space-1);"></h2>
                        <p style="color: var(--pw-text-muted); font-size: var(--pw-text-sm);" x-text="client.email"></p>
                    </div>
                    <div style="display:flex; gap: var(--pw-space-2); align-items:center;">
                        <span class="badge" :class="'badge--' + (client.status === 'activo' ? 'success' : client.status === 'prospecto' ? 'warning' : 'muted')"
                              x-text="client.status"></span>
                        <button class="btn btn--ghost btn--sm" @click="editing = !editing"
                                x-text="editing ? 'Cancelar' : 'Editar'"></button>
                    </div>
                </div>
                <div class="stats-grid" style="padding: var(--pw-space-4);">
                    <div>
                        <span style="font-size:var(--pw-text-xs); color:var(--pw-text-muted); text-transform:uppercase;">Código</span>
                        <p style="font-weight:600;" x-text="client.code || '—'"></p>
                    </div>
                    <div>
                        <span style="font-size:var(--pw-text-xs); color:var(--pw-text-muted); text-transform:uppercase;">Plan</span>
                        <p style="font-weight:600;" x-text="client.plan_type || '—'"></p>
                    </div>
                    <div>
                        <span style="font-size:var(--pw-text-xs); color:var(--pw-text-muted); text-transform:uppercase;">Teléfono</span>
                        <p style="font-weight:600;" x-text="client.phone || '—'"></p>
                    </div>
                    <div>
                        <span style="font-size:var(--pw-text-xs); color:var(--pw-text-muted); text-transform:uppercase;">Empresa</span>
                        <p style="font-weight:600;" x-text="client.company || '—'"></p>
                    </div>
                    <div>
                        <span style="font-size:var(--pw-text-xs); color:var(--pw-text-muted); text-transform:uppercase;">Registro</span>
                        <p style="font-weight:600;" x-text="client.created_at ? new Date(client.created_at).toLocaleDateString('es-CO') : '—'"></p>
                    </div>
                </div>

                <!-- Inline edit form -->
                <template x-if="editing">
                    <form @submit.prevent="save()" style="padding: var(--pw-space-4); border-top: 1px solid var(--pw-border-1);">
                        <div style="display:grid; grid-template-columns: 1fr 1fr; gap: var(--pw-space-3);">
                            <div class="form-group">
                                <label class="form-label">Nombre</label>
                                <input class="form-input" x-model="editForm.nombre">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Teléfono</label>
                                <input class="form-input" x-model="editForm.telefono">
                            </div>
                        </div>
                        <div class="form-group" style="margin-top: var(--pw-space-3);">
                            <label class="form-label">Notas</label>
                            <textarea class="form-input" x-model="editForm.notas" rows="2"></textarea>
                        </div>
                        <div style="display:flex; gap:var(--pw-space-2); justify-content:flex-end; margin-top:var(--pw-space-4);">
                            <button type="button" class="btn btn--ghost btn--sm" @click="editing = false">Cancelar</button>
                            <button type="submit" class="btn btn--primary btn--sm" :disabled="saving">
                                <span x-show="!saving">Guardar</span>
                                <span x-show="saving">Guardando...</span>
                            </button>
                        </div>
                    </form>
                </template>
            </div>

            <!-- Projects -->
            <div class="card" style="margin-bottom: var(--pw-space-5);">
                <div class="card__header">
                    <h3 class="card__title" style="font-size: var(--pw-text-base);">
                        Proyectos
                        <span style="color:var(--pw-text-muted); font-weight:normal;" x-text="'(' + projects.length + ')'"></span>
                    </h3>
                </div>
                <template x-if="projects.length === 0">
                    <p style="padding: var(--pw-space-4); color: var(--pw-text-muted); text-align:center;">Sin proyectos</p>
                </template>
                <template x-if="projects.length > 0">
                    <div class="table-wrapper">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Código</th>
                                    <th>Servicio</th>
                                    <th>Estado</th>
                                    <th>Precio</th>
                                    <th>Deadline</th>
                                </tr>
                            </thead>
                            <tbody>
                                <template x-for="p in projects" :key="p.id">
                                    <tr>
                                        <td x-text="p.project_code"></td>
                                        <td x-text="p.service_type"></td>
                                        <td><span class="badge" x-text="p.status"></span></td>
                                        <td x-text="'$' + Number(p.price_cop).toLocaleString('es-CO')"></td>
                                        <td x-text="p.deadline || '—'"></td>
                                    </tr>
                                </template>
                            </tbody>
                        </table>
                    </div>
                </template>
            </div>

            <!-- Invoices -->
            <div class="card">
                <div class="card__header">
                    <h3 class="card__title" style="font-size: var(--pw-text-base);">
                        Facturas
                        <span style="color:var(--pw-text-muted); font-weight:normal;" x-text="'(' + invoices.length + ')'"></span>
                    </h3>
                </div>
                <template x-if="invoices.length === 0">
                    <p style="padding: var(--pw-space-4); color: var(--pw-text-muted); text-align:center;">Sin facturas</p>
                </template>
                <template x-if="invoices.length > 0">
                    <div class="table-wrapper">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Número</th>
                                    <th>Monto</th>
                                    <th>Estado</th>
                                    <th>Vencimiento</th>
                                </tr>
                            </thead>
                            <tbody>
                                <template x-for="inv in invoices" :key="inv.id">
                                    <tr>
                                        <td x-text="inv.invoice_number"></td>
                                        <td x-text="'$' + Number(inv.total_cop).toLocaleString('es-CO')"></td>
                                        <td><span class="badge" :class="'badge--' + (inv.status === 'pagada' ? 'success' : inv.status === 'vencida' ? 'danger' : 'warning')"
                                                  x-text="inv.status"></span></td>
                                        <td x-text="inv.due_date || '—'"></td>
                                    </tr>
                                </template>
                            </tbody>
                        </table>
                    </div>
                </template>
            </div>

        </div>
    </template>
</div>

<style>
@keyframes pw-spin { to { transform: rotate(360deg); } }
</style>

<script>
function clientDetail() {
    const clientId = window.location.pathname.split('/').pop();

    return {
        client: null,
        projects: [],
        invoices: [],
        loading: true,
        error: '',
        editing: false,
        saving: false,
        editForm: { nombre: '', telefono: '', notas: '' },

        async load() {
            try {
                const res = await fetch('/api/v1/admin/clients/' + clientId, { credentials: 'include' });
                if (res.status === 401) { window.location.href = '/login'; return; }
                if (!res.ok) { this.error = 'Cliente no encontrado'; this.loading = false; return; }
                const data = await res.json();
                this.client   = data.data.client;
                this.projects = data.data.projects || [];
                this.invoices = data.data.invoices || [];
                this.editForm = {
                    nombre:   this.client.name   || '',
                    telefono: this.client.phone   || '',
                    notas:    this.client.notes   || '',
                };
            } catch (e) {
                this.error = 'Error al cargar datos';
            } finally {
                this.loading = false;
            }
        },

        async save() {
            this.saving = true;
            try {
                const res = await fetch('/api/v1/clients/' + this.client.id, {
                    method: 'PUT',
                    credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(this.editForm),
                });
                if (res.ok) {
                    this.editing = false;
                    this.load();
                }
            } finally {
                this.saving = false;
            }
        },
    };
}
</script>
{% endblock %}

{% block scripts %}
<script type="module" src="/dist/assets/admin.js"></script>
{% endblock %}
