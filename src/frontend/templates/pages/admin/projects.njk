{% extends "layouts/app.njk" %}

{% block title %}Proyectos — Admin ProWay Lab{% endblock %}
{% block description %}Gestión de proyectos en el panel de administración{% endblock %}
{% block page_title %}Proyectos{% endblock %}

{# ── Sidebar ─────────────────────────────────────────────── #}
{% block sidebar_nav %}
<span class="sidebar__section-title">Administración</span>

<a href="/admin" class="sidebar__link">
    <span class="sidebar__link-icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
            <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
        </svg>
    </span>
    Dashboard
</a>

<a href="/admin/clientes" class="sidebar__link">
    <span class="sidebar__link-icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
    </span>
    Clientes
</a>

<a href="/admin/proyectos" class="sidebar__link sidebar__link--active">
    <span class="sidebar__link-icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polygon points="5 3 19 12 5 21 5 3"/>
        </svg>
    </span>
    Proyectos
</a>

<a href="/admin/facturas" class="sidebar__link">
    <span class="sidebar__link-icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
        </svg>
    </span>
    Facturas
</a>
{% endblock %}

{% block sidebar_footer %}
<button class="btn btn--ghost btn--full"
        style="justify-content:flex-start; gap: var(--pw-space-2);"
        @click="fetch('/api/v1/auth/logout', {method:'POST', credentials:'include'}).then(() => window.location.href = '/login')">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
        <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
    </svg>
    Cerrar Sesión
</button>
{% endblock %}

{# ── Page actions ────────────────────────────────────────── #}
{% block page_actions %}
<span id="projects-spinner" class="htmx-indicator" aria-label="Actualizando proyectos">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
         style="animation: pw-spin 0.8s linear infinite; color: var(--pw-accent);" aria-hidden="true">
        <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
    </svg>
</span>

<button class="btn btn--ghost btn--sm"
        hx-get="/api/partials/admin-projects.php"
        hx-target="#admin-projects-container"
        hx-swap="innerHTML"
        hx-headers='{"X-Requested-With": "XMLHttpRequest"}'
        hx-indicator="#projects-spinner"
        title="Actualizar proyectos">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <polyline points="23 4 23 10 17 10"/>
        <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
    </svg>
    Actualizar
</button>

<button class="btn btn--primary btn--sm" @click="$dispatch('open-create-project')">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    Nuevo Proyecto
</button>
{% endblock %}

{# ── Main content ────────────────────────────────────────── #}
{% block content %}

<div id="admin-projects-container"
     hx-get="/api/partials/admin-projects.php"
     hx-trigger="load"
     hx-swap="innerHTML"
     hx-headers='{"X-Requested-With": "XMLHttpRequest"}'
     hx-indicator="#projects-spinner">

    <!-- Skeleton card grid while loading -->
    <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: var(--pw-space-4);" aria-busy="true" aria-label="Cargando proyectos">
        {% for i in range(0, 6) %}
        <div class="card loading-skeleton" aria-hidden="true" style="min-height: 140px;">
            <div class="card__header">
                <span class="skeleton-text" style="width: 55%; height: 16px;"></span>
                <span class="skeleton-text" style="width: 60px; border-radius: var(--pw-radius-full); height: 22px;"></span>
            </div>
            <div style="padding: var(--pw-space-4); display:flex; flex-direction:column; gap: var(--pw-space-3);">
                <span class="skeleton-text" style="width: 80%;"></span>
                <span class="skeleton-text" style="width: 50%;"></span>
                <div style="display:flex; gap: var(--pw-space-2); margin-top: var(--pw-space-2);">
                    <span class="skeleton-text" style="width: 70px; height: 30px; border-radius: var(--pw-radius-sm);"></span>
                    <span class="skeleton-text" style="width: 70px; height: 30px; border-radius: var(--pw-radius-sm);"></span>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>

</div>

<style>
@keyframes pw-spin { to { transform: rotate(360deg); } }

@keyframes pw-skeleton-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.35; }
}
.loading-skeleton { pointer-events: none; animation: pw-skeleton-pulse 1.4s ease-in-out infinite; }
.skeleton-text {
    display: inline-block;
    height: 14px;
    background: var(--pw-border-2);
    border-radius: var(--pw-radius-sm);
    animation: pw-skeleton-pulse 1.4s ease-in-out infinite;
}

.htmx-indicator { opacity: 0; transition: opacity 0.2s; pointer-events: none; }
.htmx-request .htmx-indicator,
.htmx-indicator.htmx-request { opacity: 1; }
</style>

<script>
document.body.addEventListener('htmx:responseError', function(evt) {
    if (evt.detail.xhr.status === 401) {
        window.location.href = '/login';
    }
});
</script>

{# ── Modal: Nuevo Proyecto ────────────────────────────────── #}
<div x-data="createProjectForm()"
     @open-create-project.window="open()"
     x-show="isOpen"
     x-cloak
     style="position:fixed;inset:0;z-index:1000;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.6);"
     @keydown.escape.window="close()">

    <div class="card" style="width:100%;max-width:520px;max-height:90vh;overflow-y:auto;margin:var(--pw-space-4);" @click.stop>
        <div class="card__header">
            <h2 style="margin:0;font-size:1rem;font-weight:600;">Nuevo Proyecto</h2>
            <button class="btn btn--ghost btn--sm" @click="close()" aria-label="Cerrar"
                    style="padding:4px;line-height:1;">✕</button>
        </div>

        <form @submit.prevent="submit()" style="padding:var(--pw-space-4);display:flex;flex-direction:column;gap:var(--pw-space-3);">

            <div class="form-group">
                <label class="form-label">Cliente *</label>
                <select class="form-input" x-model="form.client_id" required>
                    <option value="">— seleccionar —</option>
                    <template x-for="c in clients" :key="c.id">
                        <option :value="c.id" x-text="c.nombre || c.name"></option>
                    </template>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Tipo de servicio *</label>
                <select class="form-input" x-model="form.service_type" required>
                    <option value="">— seleccionar —</option>
                    <option value="Video Elite">Video Elite</option>
                    <option value="Paquete Growth">Paquete Growth</option>
                    <option value="Paquete Starter">Paquete Starter</option>
                    <option value="Reels Básico">Reels Básico</option>
                    <option value="Identidad de Marca">Identidad de Marca</option>
                    <option value="Consultoría">Consultoría</option>
                    <option value="Otro">Otro</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Título del proyecto</label>
                <input class="form-input" type="text" x-model="form.title" placeholder="Ej: Reels Mayo 2026">
            </div>

            <div class="form-group">
                <label class="form-label">Precio (COP) *</label>
                <input class="form-input" type="number" min="0" step="1000" x-model="form.price_cop" required placeholder="0">
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--pw-space-3);">
                <div class="form-group">
                    <label class="form-label">Inicio</label>
                    <input class="form-input" type="date" x-model="form.start_date">
                </div>
                <div class="form-group">
                    <label class="form-label">Entrega</label>
                    <input class="form-input" type="date" x-model="form.deadline">
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Estado inicial</label>
                <select class="form-input" x-model="form.status">
                    <option value="cotizacion">Cotización</option>
                    <option value="confirmado">Confirmado</option>
                    <option value="en_produccion">En Producción</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Descripción / notas</label>
                <textarea class="form-input" rows="3" x-model="form.notes" placeholder="Detalles del proyecto..."></textarea>
            </div>

            <p x-show="error" x-text="error" class="text-error" style="margin:0;font-size:.85rem;"></p>

            <div style="display:flex;gap:var(--pw-space-2);justify-content:flex-end;padding-top:var(--pw-space-2);">
                <button type="button" class="btn btn--ghost btn--sm" @click="close()">Cancelar</button>
                <button type="submit" class="btn btn--primary btn--sm" :disabled="loading">
                    <span x-show="loading">Guardando…</span>
                    <span x-show="!loading">Crear Proyecto</span>
                </button>
            </div>
        </form>
    </div>
</div>

{% endblock %}

{% block scripts %}
<script type="module" src="/dist/assets/admin.js"></script>
<script>
function createProjectForm() {
    return {
        isOpen:  false,
        loading: false,
        error:   '',
        clients: [],
        form: {
            client_id:    '',
            service_type: '',
            title:        '',
            price_cop:    '',
            start_date:   '',
            deadline:     '',
            status:       'cotizacion',
            notes:        '',
        },

        async open() {
            this.isOpen = true;
            if (this.clients.length === 0) await this.loadClients();
        },

        close() {
            this.isOpen  = false;
            this.error   = '';
            this.loading = false;
            Object.keys(this.form).forEach(k => {
                this.form[k] = k === 'status' ? 'cotizacion' : '';
            });
        },

        async loadClients() {
            try {
                const res  = await fetch('/api/v1/clients', { credentials: 'include' });
                const json = await res.json();
                this.clients = json.data ?? [];
            } catch {
                this.clients = [];
            }
        },

        async submit() {
            this.error   = '';
            this.loading = true;
            try {
                const res  = await fetch('/api/v1/admin/projects', {
                    method:      'POST',
                    credentials: 'include',
                    headers:     { 'Content-Type': 'application/json' },
                    body:        JSON.stringify(this.form),
                });
                const json = await res.json();
                if (!res.ok) {
                    this.error = json.message ?? 'Error al crear el proyecto';
                    return;
                }
                this.close();
                // Refresh the projects table
                htmx.trigger('#admin-projects-container', 'load');
            } catch {
                this.error = 'Error de conexión. Intenta de nuevo.';
            } finally {
                this.loading = false;
            }
        },
    };
}
</script>
{% endblock %}
