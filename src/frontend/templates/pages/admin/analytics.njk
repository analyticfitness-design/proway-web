{% extends "layouts/app.njk" %}

{% block title %}Analytics — ProWay Lab{% endblock %}
{% block description %}Panel de analíticas financieras ProWay Lab{% endblock %}
{% block page_title %}Analytics PRO{% endblock %}

{% block head %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
{% endblock %}

{# ── Sidebar ─────────────────────────────────────────────── #}
{% block sidebar_nav %}
<span class="sidebar__section-title">Administración</span>

<a href="/admin" class="sidebar__link">
    <span class="sidebar__link-icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
            <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
        </svg>
    </span>
    Dashboard
</a>

<a href="/admin/analytics" class="sidebar__link sidebar__link--active">
    <span class="sidebar__link-icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/>
            <path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/>
            <path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/>
        </svg>
    </span>
    Analytics
</a>

<a href="/admin/clientes" class="sidebar__link">
    <span class="sidebar__link-icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
    </span>
    Clientes
</a>

<a href="/admin/proyectos" class="sidebar__link">
    <span class="sidebar__link-icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polygon points="5 3 19 12 5 21 5 3"/>
        </svg>
    </span>
    Proyectos
</a>

<a href="/admin/facturas" class="sidebar__link">
    <span class="sidebar__link-icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
        </svg>
    </span>
    Facturas
</a>
{% endblock %}

{% block sidebar_footer %}
<button class="btn btn--ghost btn--full"
        style="justify-content:flex-start; gap: var(--pw-space-2);"
        @click="fetch('/api/v1/auth/logout', {method:'POST', credentials:'include'}).then(() => window.location.href = '/login')">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
        <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
    </svg>
    Cerrar Sesión
</button>
{% endblock %}

{# ── Page actions ────────────────────────────────────────── #}
{% block page_actions %}
<span id="global-spinner" class="htmx-indicator" aria-label="Actualizando">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
         style="animation: pw-spin 0.8s linear infinite; color: var(--pw-accent);" aria-hidden="true">
        <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
    </svg>
</span>

<button class="btn btn--ghost btn--sm"
        hx-get="/api/partials/admin-analytics.php"
        hx-target="#analytics-kpis"
        hx-swap="innerHTML"
        hx-headers='{"X-Requested-With": "XMLHttpRequest"}'
        hx-indicator="#global-spinner"
        hx-trigger="click"
        title="Refrescar métricas">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <polyline points="23 4 23 10 17 10"/>
        <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
    </svg>
    Actualizar
</button>
{% endblock %}

{# ── Main content ────────────────────────────────────────── #}
{% block content %}

<!-- KPI Cards -->
<div class="section-label">Métricas Financieras</div>
<div id="analytics-kpis"
     hx-get="/api/partials/admin-analytics.php"
     hx-trigger="load"
     hx-swap="innerHTML"
     hx-headers='{"X-Requested-With": "XMLHttpRequest"}'
     hx-indicator="#global-spinner"
     class="stats-grid"
     style="grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));">

    <!-- Skeleton placeholders -->
    <div class="stat-card loading-skeleton" aria-hidden="true">
        <div class="stat-card__value" style="color: var(--pw-text-muted);">—</div>
        <div class="stat-card__label">Cargando...</div>
    </div>
    <div class="stat-card loading-skeleton" aria-hidden="true">
        <div class="stat-card__value" style="color: var(--pw-text-muted);">—</div>
        <div class="stat-card__label">Cargando...</div>
    </div>
    <div class="stat-card loading-skeleton" aria-hidden="true">
        <div class="stat-card__value" style="color: var(--pw-text-muted);">—</div>
        <div class="stat-card__label">Cargando...</div>
    </div>
    <div class="stat-card loading-skeleton" aria-hidden="true">
        <div class="stat-card__value" style="color: var(--pw-text-muted);">—</div>
        <div class="stat-card__label">Cargando...</div>
    </div>
    <div class="stat-card loading-skeleton" aria-hidden="true">
        <div class="stat-card__value" style="color: var(--pw-text-muted);">—</div>
        <div class="stat-card__label">Cargando...</div>
    </div>
    <div class="stat-card loading-skeleton" aria-hidden="true">
        <div class="stat-card__value" style="color: var(--pw-text-muted);">—</div>
        <div class="stat-card__label">Cargando...</div>
    </div>
    <div class="stat-card loading-skeleton" aria-hidden="true">
        <div class="stat-card__value" style="color: var(--pw-text-muted);">—</div>
        <div class="stat-card__label">Cargando...</div>
    </div>
</div>

<!-- Charts -->
<div class="section-label" style="margin-top: var(--pw-space-4);">Visualizaciones</div>
<div id="analytics-charts"
     hx-get="/api/partials/admin-analytics-charts.php"
     hx-trigger="load"
     hx-swap="innerHTML"
     hx-headers='{"X-Requested-With": "XMLHttpRequest"}'
     hx-indicator="#global-spinner"
     style="margin-bottom: var(--pw-space-4);">

    <!-- Skeleton chart placeholders -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--pw-space-4); margin-bottom: var(--pw-space-4);">
        <div class="card loading-skeleton" aria-hidden="true" style="padding: var(--pw-space-4);">
            <div class="skeleton-text" style="width: 240px; height: 16px; margin-bottom: var(--pw-space-3);"></div>
            <div class="skeleton-text" style="width: 100%; height: 300px; border-radius: var(--pw-radius-md);"></div>
        </div>
        <div class="card loading-skeleton" aria-hidden="true" style="padding: var(--pw-space-4);">
            <div class="skeleton-text" style="width: 160px; height: 16px; margin-bottom: var(--pw-space-3);"></div>
            <div class="skeleton-text" style="width: 100%; height: 300px; border-radius: var(--pw-radius-md);"></div>
        </div>
    </div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--pw-space-4);">
        <div class="card loading-skeleton" aria-hidden="true" style="padding: var(--pw-space-4);">
            <div class="skeleton-text" style="width: 200px; height: 16px; margin-bottom: var(--pw-space-3);"></div>
            <div class="skeleton-text" style="width: 100%; height: 300px; border-radius: var(--pw-radius-md);"></div>
        </div>
        <div class="card loading-skeleton" aria-hidden="true" style="padding: var(--pw-space-4);">
            <div class="skeleton-text" style="width: 220px; height: 16px; margin-bottom: var(--pw-space-3);"></div>
            <div class="skeleton-text" style="width: 100%; height: 300px; border-radius: var(--pw-radius-md);"></div>
        </div>
    </div>
</div>

<style>
@keyframes pw-spin { to { transform: rotate(360deg); } }

@keyframes pw-skeleton-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.35; }
}
.loading-skeleton { pointer-events: none; }
.skeleton-text {
    display: inline-block;
    height: 14px;
    background: var(--pw-border-2);
    border-radius: var(--pw-radius-sm);
    animation: pw-skeleton-pulse 1.4s ease-in-out infinite;
}

.htmx-indicator { opacity: 0; transition: opacity 0.2s; pointer-events: none; }
.htmx-request .htmx-indicator,
.htmx-indicator.htmx-request { opacity: 1; }

@media (max-width: 768px) {
    #analytics-kpis {
        grid-template-columns: repeat(2, 1fr) !important;
    }
}
</style>

<script>
document.body.addEventListener('htmx:responseError', function(evt) {
    if (evt.detail.xhr.status === 401) {
        window.location.href = '/login';
    }
});
</script>
{% endblock %}

{% block scripts %}
<script type="module" src="/dist/assets/admin.js"></script>
{% endblock %}
