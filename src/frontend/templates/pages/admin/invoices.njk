{% block sidebar_footer %}
<button class="btn btn--ghost btn--full"
        style="justify-content:flex-start; gap: var(--pw-space-2);"
        @click="fetch('/api/v1/auth/logout', {method:'POST', credentials:'include'}).then(() => window.location.href = '/login')">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
        <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
    </svg>
    Cerrar Sesión
</button>
{% endblock %}

{# ── Page actions ────────────────────────────────────────── #}
{% block page_actions %}
<span id="inv-spinner" class="htmx-indicator" aria-label="Cargando facturas">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
         style="animation: pw-spin 0.8s linear infinite; color: var(--pw-accent);" aria-hidden="true">
        <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
    </svg>
</span>

<button class="btn btn--ghost btn--sm"
        hx-get="/api/partials/admin-invoices.php"
        hx-target="#admin-invoices-container"
        hx-swap="innerHTML"
        hx-headers='{"X-Requested-With": "XMLHttpRequest"}'
        hx-indicator="#inv-spinner"
        title="Actualizar facturas">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <polyline points="23 4 23 10 17 10"/>
        <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
    </svg>
    Actualizar
</button>

<button class="btn btn--primary btn--sm" @click="$dispatch('open-create-invoice')">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    Nueva Factura
</button>
{% endblock %}

{# ── Main content ────────────────────────────────────────── #}
{% block content %}

<div class="card">
    <div class="card__header">
        <h2 class="card__title">Todas las Facturas</h2>
    </div>

    <div id="admin-invoices-container"
         hx-get="/api/partials/admin-invoices.php"
         hx-trigger="load"
         hx-swap="innerHTML"
         hx-headers='{"X-Requested-With": "XMLHttpRequest"}'
         hx-indicator="#inv-spinner">

        <!-- Skeleton table while loading -->
        <div class="table-wrapper" aria-busy="true" aria-label="Cargando facturas">
            <table class="table">
                <thead>
                    <tr>
                        <th>N° Factura</th>
                        <th>Cliente</th>
                        <th>Concepto</th>
                        <th>Total</th>
                        <th>Estado</th>
                        <th>Vencimiento</th>
                    </tr>
                </thead>
                <tbody>
                    {% for i in range(0, 5) %}
                    <tr class="loading-skeleton" aria-hidden="true">
                        <td><span class="skeleton-text" style="width: 90px;"></span></td>
                        <td><span class="skeleton-text" style="width: 120px;"></span></td>
                        <td><span class="skeleton-text" style="width: 150px;"></span></td>
                        <td><span class="skeleton-text" style="width: 80px;"></span></td>
                        <td><span class="skeleton-text" style="width: 70px; border-radius: var(--pw-radius-full);"></span></td>
                        <td><span class="skeleton-text" style="width: 80px;"></span></td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

    </div>
</div>

<style>
@keyframes pw-spin { to { transform: rotate(360deg); } }
@keyframes pw-skeleton-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.35; }
}
.loading-skeleton { pointer-events: none; }
.skeleton-text {
    display: inline-block;
    height: 14px;
    background: var(--pw-border-2);
    border-radius: var(--pw-radius-sm);
    animation: pw-skeleton-pulse 1.4s ease-in-out infinite;
}
.htmx-indicator { opacity: 0; transition: opacity 0.2s; pointer-events: none; }
.htmx-request .htmx-indicator,
.htmx-indicator.htmx-request { opacity: 1; }
</style>

<script>
document.body.addEventListener('htmx:responseError', function(evt) {
    if (evt.detail.xhr.status === 401) { window.location.href = '/login'; }
});
</script>

{# ── Modal: Nueva Factura ─────────────────────────────── #}
<div x-data="createInvoiceForm()"
     @open-create-invoice.window="open()"
     x-show="isOpen"
     x-cloak
     style="position:fixed;inset:0;z-index:1000;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.6);"
     @keydown.escape.window="close()">

    <div class="card" style="width:100%;max-width:480px;max-height:90vh;overflow-y:auto;margin:var(--pw-space-4);" @click.stop>
        <div class="card__header">
            <h2 style="margin:0;font-size:1rem;font-weight:600;">Nueva Factura</h2>
            <button class="btn btn--ghost btn--sm" @click="close()" aria-label="Cerrar"
                    style="padding:4px;line-height:1;">✕</button>
        </div>

        <form @submit.prevent="submit()" style="padding:var(--pw-space-4);display:flex;flex-direction:column;gap:var(--pw-space-3);">

            <div class="form-group">
                <label class="form-label">Cliente *</label>
                <select class="form-input" x-model="form.client_id" required>
                    <option value="">— seleccionar —</option>
                    <template x-for="c in clients" :key="c.id">
                        <option :value="c.id" x-text="c.nombre || c.name"></option>
                    </template>
                </select>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--pw-space-3);">
                <div class="form-group">
                    <label class="form-label">Subtotal (COP) *</label>
                    <input class="form-input" type="number" min="0" step="1000" x-model="form.amount_cop" required @input="updateTotal()">
                </div>
                <div class="form-group">
                    <label class="form-label">IVA (COP)</label>
                    <input class="form-input" type="number" min="0" step="1000" x-model="form.tax_cop" @input="updateTotal()">
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Total</label>
                <input class="form-input" type="text" :value="totalFormatted" readonly style="background:var(--pw-bg-2);color:var(--pw-accent);font-weight:600;">
            </div>

            <div class="form-group">
                <label class="form-label">Concepto / notas</label>
                <textarea class="form-input" rows="2" x-model="form.notes" placeholder="Servicios de producción de video…"></textarea>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--pw-space-3);">
                <div class="form-group">
                    <label class="form-label">Vencimiento</label>
                    <input class="form-input" type="date" x-model="form.due_date">
                </div>
                <div class="form-group">
                    <label class="form-label">Estado</label>
                    <select class="form-input" x-model="form.status">
                        <option value="enviada">Enviada</option>
                        <option value="pendiente">Pendiente</option>
                        <option value="borrador">Borrador</option>
                    </select>
                </div>
            </div>

            <p x-show="error" x-text="error" class="text-error" style="margin:0;font-size:.85rem;"></p>

            <div style="display:flex;gap:var(--pw-space-2);justify-content:flex-end;padding-top:var(--pw-space-2);">
                <button type="button" class="btn btn--ghost btn--sm" @click="close()">Cancelar</button>
                <button type="submit" class="btn btn--primary btn--sm" :disabled="loading">
                    <span x-show="loading">Guardando…</span>
                    <span x-show="!loading">Crear Factura</span>
                </button>
            </div>
        </form>
    </div>
</div>

{% endblock %}

{% block scripts %}
<script type="module" src="/dist/assets/admin.js"></script>
<script>
function createInvoiceForm() {
    return {
        isOpen:  false,
        loading: false,
        error:   '',
        clients: [],
        form: {
            client_id:  '',
            amount_cop: '',
            tax_cop:    '0',
            notes:      '',
            due_date:   '',
            status:     'enviada',
        },

        get totalFormatted() {
            const t = (parseFloat(this.form.amount_cop) || 0) + (parseFloat(this.form.tax_cop) || 0);
            return t > 0 ? '$' + t.toLocaleString('es-CO') + ' COP' : '—';
        },

        updateTotal() { /* reactive via getter */ },

        async open() {
            this.isOpen = true;
            if (this.clients.length === 0) await this.loadClients();
        },

        close() {
            this.isOpen  = false;
            this.error   = '';
            this.loading = false;
            Object.assign(this.form, { client_id:'', amount_cop:'', tax_cop:'0', notes:'', due_date:'', status:'enviada' });
        },

        async loadClients() {
            try {
                const res  = await fetch('/api/v1/clients', { credentials: 'include' });
                const json = await res.json();
                this.clients = json.data ?? [];
            } catch { this.clients = []; }
        },

        async submit() {
            this.error   = '';
            this.loading = true;
            try {
                const res  = await fetch('/api/v1/admin/invoices', {
                    method:      'POST',
                    credentials: 'include',
                    headers:     { 'Content-Type': 'application/json' },
                    body:        JSON.stringify(this.form),
                });
                const json = await res.json();
                if (!res.ok) { this.error = json.message ?? 'Error al crear la factura'; return; }
                this.close();
                htmx.trigger('#admin-invoices-container', 'load');
            } catch {
                this.error = 'Error de conexión. Intenta de nuevo.';
            } finally {
                this.loading = false;
            }
        },
    };
}
</script>
{% endblock %}
