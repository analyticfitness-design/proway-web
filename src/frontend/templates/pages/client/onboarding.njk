{% extends "layouts/app.njk" %}

{% block title %}Onboarding — ProWay Lab{% endblock %}
{% block description %}Configura tu perfil de marca en ProWay Lab{% endblock %}
{% block page_title %}Configurar mi marca{% endblock %}

{# ── Sidebar ─────────────────────────────────────────────── #}
{% block sidebar_nav %}
<span class="sidebar__section-title">Onboarding</span>

<a href="/onboarding" class="sidebar__link sidebar__link--active">
    <span class="sidebar__link-icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
        </svg>
    </span>
    Configurar marca
</a>

<a href="/portal" class="sidebar__link">
    <span class="sidebar__link-icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
            <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
        </svg>
    </span>
    Dashboard
</a>

<a href="/perfil" class="sidebar__link">
    <span class="sidebar__link-icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
        </svg>
    </span>
    Mi Perfil
</a>
{% endblock %}

{% block sidebar_footer %}
<button class="btn btn--ghost btn--full"
        style="justify-content:flex-start; gap: var(--pw-space-2);"
        @click="fetch('/api/v1/auth/logout', {method:'POST', credentials:'include'}).then(() => window.location.href = '/login')">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
        <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
    </svg>
    Cerrar Sesion
</button>
{% endblock %}

{# ── Main content ────────────────────────────────────────── #}
{% block content %}

<div id="onboarding-container"
     hx-get="/api/partials/onboarding-wizard.php"
     hx-trigger="load"
     hx-swap="innerHTML"
     hx-headers='{"X-Requested-With": "XMLHttpRequest"}'>

    <!-- Loading skeleton -->
    <div style="max-width: 680px; margin: 0 auto;">
        <!-- Step indicator skeleton -->
        <div style="display: flex; justify-content: center; gap: var(--pw-space-8); margin-bottom: var(--pw-space-8);">
            <div style="display: flex; flex-direction: column; align-items: center; gap: var(--pw-space-2);">
                <div class="loading-skeleton" style="width: 40px; height: 40px; border-radius: 50%; background: var(--pw-panel); border: 2px solid var(--pw-border);"></div>
                <div class="loading-skeleton" style="width: 40px; height: 10px; border-radius: 4px; background: var(--pw-panel);"></div>
            </div>
            <div style="display: flex; flex-direction: column; align-items: center; gap: var(--pw-space-2);">
                <div class="loading-skeleton" style="width: 40px; height: 40px; border-radius: 50%; background: var(--pw-panel); border: 2px solid var(--pw-border);"></div>
                <div class="loading-skeleton" style="width: 40px; height: 10px; border-radius: 4px; background: var(--pw-panel);"></div>
            </div>
            <div style="display: flex; flex-direction: column; align-items: center; gap: var(--pw-space-2);">
                <div class="loading-skeleton" style="width: 40px; height: 40px; border-radius: 50%; background: var(--pw-panel); border: 2px solid var(--pw-border);"></div>
                <div class="loading-skeleton" style="width: 40px; height: 10px; border-radius: 4px; background: var(--pw-panel);"></div>
            </div>
            <div style="display: flex; flex-direction: column; align-items: center; gap: var(--pw-space-2);">
                <div class="loading-skeleton" style="width: 40px; height: 40px; border-radius: 50%; background: var(--pw-panel); border: 2px solid var(--pw-border);"></div>
                <div class="loading-skeleton" style="width: 40px; height: 10px; border-radius: 4px; background: var(--pw-panel);"></div>
            </div>
        </div>

        <!-- Panel skeleton -->
        <div class="loading-skeleton" style="background: var(--pw-panel); border: 1px solid var(--pw-border); border-radius: 12px; padding: var(--pw-space-8); min-height: 300px;">
            <div style="width: 160px; height: 20px; background: var(--pw-border); border-radius: 4px; margin-bottom: var(--pw-space-4);"></div>
            <div style="width: 300px; height: 14px; background: var(--pw-border); border-radius: 4px; margin-bottom: var(--pw-space-8);"></div>
            <div style="width: 100%; height: 44px; background: var(--pw-border); border-radius: 6px; margin-bottom: var(--pw-space-4);"></div>
            <div style="width: 100%; height: 44px; background: var(--pw-border); border-radius: 6px;"></div>
        </div>
    </div>
</div>

<style>
@keyframes pw-skeleton-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
}
.loading-skeleton { animation: pw-skeleton-pulse 1.5s ease-in-out infinite; }
</style>

<script>
/* Redirect to login on 401 */
document.body.addEventListener('htmx:responseError', function(evt) {
    if (evt.detail.xhr.status === 401) {
        window.location.href = '/login';
    }
});
</script>
{% endblock %}
