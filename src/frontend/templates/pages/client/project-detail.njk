{% extends "layouts/app.njk" %}

{% block title %}Detalle de Proyecto — ProWay Lab{% endblock %}
{% block description %}Información detallada de tu proyecto en ProWay Lab{% endblock %}
{% block page_title %}<span x-text="project ? (project.title || project.project_code) : 'Proyecto'">Proyecto</span>{% endblock %}

{# ── Sidebar ─────────────────────────────────────────────── #}
{% block sidebar_nav %}
<span class="sidebar__section-title">Mi Cuenta</span>

<a href="/portal" class="sidebar__link">
    <span class="sidebar__link-icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
            <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
        </svg>
    </span>
    Dashboard
</a>

<a href="/proyectos" class="sidebar__link sidebar__link--active">
    <span class="sidebar__link-icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polygon points="5 3 19 12 5 21 5 3"/>
        </svg>
    </span>
    Mis Proyectos
</a>

<a href="/facturas" class="sidebar__link">
    <span class="sidebar__link-icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
        </svg>
    </span>
    Facturas
</a>

<a href="/perfil" class="sidebar__link">
    <span class="sidebar__link-icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
        </svg>
    </span>
    Mi Perfil
</a>
{% endblock %}

{% block sidebar_footer %}
<button class="btn btn--ghost btn--full"
        style="justify-content:flex-start; gap: var(--pw-space-2);"
        @click="fetch('/api/v1/auth/logout', {method:'POST', credentials:'include'}).then(() => window.location.href = '/login')">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
        <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
    </svg>
    Cerrar Sesión
</button>
{% endblock %}

{# ── Page actions ────────────────────────────────────────── #}
{% block page_actions %}
<a href="/proyectos" class="btn btn--ghost btn--sm">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
    </svg>
    Volver
</a>
{% endblock %}

{# ── Main content ────────────────────────────────────────── #}
{% block content %}

<div x-data="projectDetail()" x-init="load()">

    <!-- Loading skeleton -->
    <template x-if="loading">
        <div style="display:grid;gap:var(--pw-space-4);">
            <div class="card" style="padding:var(--pw-space-6);">
                <div style="display:flex;gap:var(--pw-space-3);align-items:center;margin-bottom:var(--pw-space-4);">
                    <span class="skeleton-text" style="width:180px;height:20px;"></span>
                    <span class="skeleton-text" style="width:90px;height:24px;border-radius:var(--pw-radius-full);"></span>
                </div>
                <span class="skeleton-text" style="width:100%;height:14px;margin-bottom:8px;display:block;"></span>
                <span class="skeleton-text" style="width:70%;height:14px;display:block;"></span>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:var(--pw-space-4);">
                <div class="card" style="padding:var(--pw-space-4);"><span class="skeleton-text" style="width:80%;height:14px;display:block;margin-bottom:8px;"></span><span class="skeleton-text" style="width:60%;height:20px;display:block;"></span></div>
                <div class="card" style="padding:var(--pw-space-4);"><span class="skeleton-text" style="width:80%;height:14px;display:block;margin-bottom:8px;"></span><span class="skeleton-text" style="width:60%;height:20px;display:block;"></span></div>
                <div class="card" style="padding:var(--pw-space-4);"><span class="skeleton-text" style="width:80%;height:14px;display:block;margin-bottom:8px;"></span><span class="skeleton-text" style="width:60%;height:20px;display:block;"></span></div>
            </div>
        </div>
    </template>

    <!-- Error state -->
    <template x-if="!loading && error">
        <div class="card" style="padding:var(--pw-space-8);text-align:center;">
            <p style="color:var(--pw-accent);margin-bottom:var(--pw-space-3);" x-text="error"></p>
            <a href="/proyectos" class="btn btn--ghost btn--sm">← Volver a Proyectos</a>
        </div>
    </template>

    <!-- Project content -->
    <template x-if="!loading && project">
        <div style="display:grid;gap:var(--pw-space-4);">

            <!-- Header card -->
            <div class="card">
                <div class="card__header">
                    <div>
                        <div style="display:flex;align-items:center;gap:var(--pw-space-3);flex-wrap:wrap;">
                            <h2 class="card__title" x-text="project.title || project.project_code"></h2>
                            <span class="badge" :class="statusClass(project.status)" x-text="statusLabel(project.status)"></span>
                        </div>
                        <p style="font-size:var(--pw-text-sm);color:var(--pw-text-muted);margin-top:var(--pw-space-1);" x-text="project.project_code"></p>
                    </div>
                </div>

                <template x-if="project.description">
                    <div style="padding:0 var(--pw-space-5) var(--pw-space-5);">
                        <p style="font-size:var(--pw-text-sm);color:var(--pw-text-secondary);line-height:1.6;" x-text="project.description"></p>
                    </div>
                </template>
            </div>

            <!-- Stats grid -->
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:var(--pw-space-4);">

                <div class="card" style="padding:var(--pw-space-4);">
                    <p style="font-size:var(--pw-text-xs);color:var(--pw-text-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:var(--pw-space-1);">Servicio</p>
                    <p style="font-weight:600;" x-text="project.service_type || '—'"></p>
                </div>

                <div class="card" style="padding:var(--pw-space-4);">
                    <p style="font-size:var(--pw-text-xs);color:var(--pw-text-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:var(--pw-space-1);">Valor</p>
                    <p style="font-weight:600;" x-text="formatCOP(project.price_cop)"></p>
                </div>

                <div class="card" style="padding:var(--pw-space-4);">
                    <p style="font-size:var(--pw-text-xs);color:var(--pw-text-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:var(--pw-space-1);">Inicio</p>
                    <p style="font-weight:600;" x-text="formatDate(project.start_date)"></p>
                </div>

                <div class="card" style="padding:var(--pw-space-4);">
                    <p style="font-size:var(--pw-text-xs);color:var(--pw-text-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:var(--pw-space-1);">Entrega</p>
                    <p style="font-weight:600;" x-text="formatDate(project.deadline)"></p>
                </div>

            </div>

            <!-- Progress bar -->
            <div class="card" style="padding:var(--pw-space-5);">
                <p style="font-size:var(--pw-text-sm);font-weight:500;margin-bottom:var(--pw-space-3);">Progreso del proyecto</p>
                <div style="background:var(--pw-border-2);border-radius:var(--pw-radius-full);height:8px;overflow:hidden;">
                    <div style="height:100%;border-radius:var(--pw-radius-full);background:var(--pw-accent);transition:width .5s ease;"
                         :style="{ width: progressPercent(project.status) + '%' }"></div>
                </div>
                <p style="font-size:var(--pw-text-xs);color:var(--pw-text-muted);margin-top:var(--pw-space-2);" x-text="progressPercent(project.status) + '% completado'"></p>
            </div>

            <!-- Notes -->
            <template x-if="project.notes">
                <div class="card" style="padding:var(--pw-space-5);">
                    <p style="font-size:var(--pw-text-sm);font-weight:500;margin-bottom:var(--pw-space-2);">Notas</p>
                    <p style="font-size:var(--pw-text-sm);color:var(--pw-text-secondary);line-height:1.6;" x-text="project.notes"></p>
                </div>
            </template>

        </div>
    </template>

</div>

<style>
@keyframes pw-skeleton-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.35; }
}
.skeleton-text {
    display: inline-block;
    height: 14px;
    background: var(--pw-border-2);
    border-radius: var(--pw-radius-sm);
    animation: pw-skeleton-pulse 1.4s ease-in-out infinite;
}
.badge { display:inline-flex;align-items:center;padding:2px 10px;border-radius:var(--pw-radius-full);font-size:var(--pw-text-xs);font-weight:500; }
.badge--blue   { background:rgba(99,102,241,.15);color:#818cf8; }
.badge--yellow { background:rgba(250,204,21,.15);color:#fbbf24; }
.badge--orange { background:rgba(249,115,22,.15);color:#fb923c; }

.badge--green  { background:rgba(34,197,94,.15); color:#4ade80; }
.badge--red    { background:rgba(239,68,68,.15); color:#f87171; }
</style>

<script>
function projectDetail() {
    return {
        loading: true,
        error: '',
        project: null,

        async load() {
            const parts = window.location.pathname.split('/').filter(Boolean);
            const id = parts[1]; // /proyectos/{id}
            if (!id || isNaN(id)) {
                this.error = 'ID de proyecto inválido';
                this.loading = false;
                return;
            }
            try {
                const res = await fetch('/api/v1/projects/' + id, { credentials: 'include' });
                if (res.status === 401) { window.location.href = '/login'; return; }
                if (res.status === 404) { this.error = 'Proyecto no encontrado'; this.loading = false; return; }
                const data = await res.json();
                this.project = data?.data?.project ?? null;
                if (!this.project) this.error = 'No se pudo cargar el proyecto';
            } catch (e) {
                this.error = 'Error de conexión';
            } finally {
                this.loading = false;
            }
        },

        statusLabel(s) {
            const map = { cotizacion:'Cotización', confirmado:'Confirmado', en_produccion:'En Producción',
                          revision:'Revisión', completado:'Completado', cancelado:'Cancelado' };
            return map[s] || s;
        },

        statusClass(s) {
            const map = { cotizacion:'badge--blue', confirmado:'badge--yellow', en_produccion:'badge--orange',
                          revision:'badge--revision', completado:'badge--green', cancelado:'badge--red' };
            return 'badge ' + (map[s] || 'badge--blue');
        },

        progressPercent(s) {
            const map = { cotizacion:5, confirmado:20, en_produccion:60, revision:85, completado:100, cancelado:0 };
            return map[s] ?? 0;
        },

        formatCOP(v) {
            if (!v) return '—';
            return new Intl.NumberFormat('es-CO', { style:'currency', currency:'COP', maximumFractionDigits:0 }).format(v);
        },

        formatDate(d) {
            if (!d) return '—';
            return new Date(d).toLocaleDateString('es-CO', { year:'numeric', month:'short', day:'numeric' });
        },
    };
}
</script>
{% endblock %}

{% block scripts %}
<script type="module" src="/dist/assets/main.js"></script>
{% endblock %}
