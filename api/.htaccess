# ProWay Lab API — Apache Security Rules

# Block direct access to sensitive file types
<FilesMatch "\.(sql|log|env|md)$">
    Require all denied
</FilesMatch>

# Block direct browser access to seed/schema scripts
<FilesMatch "^(seed|schema)\.(php|sql)$">
    Require all denied
</FilesMatch>

# Disable directory listings
Options -Indexes

# Block access to config/ and includes/ directories
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct access to config/
    RewriteRule ^config/ - [F,L]

    # Block direct access to includes/
    RewriteRule ^includes/ - [F,L]

    # Block direct access to setup/
    RewriteRule ^setup/ - [F,L]

    # If the requested file does not exist, return 404 (no directory listing)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule . - [R=404,L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
