{
    "name": "prowaylab/api",
    "description": "ProWay Lab API — Video production agency client portal",
    "type": "project",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.0",
        "robmorgan/phinx": "^0.16"
    },
    "autoload": {
        "psr-4": {
            "ProWay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ProWay\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "test":     "phpunit",
        "analyse":  "phpstan analyse src --level=5",
        "lint":     "php-cs-fixer check --diff"
    }
}
